# Local state
.wotw
.git
.github
.husky

# Review item 5: secrets must never bake into image layers via COPY . .
# Local dev .env files (and their sibling drop-ins) are explicitly ignored
# so a developer's loose ANTHROPIC_API_KEY / OPENAI_API_KEY can't escape
# into the published daemon image.
.env
.env.*
*.env
*.env.*

# Audit / planning markdown — not part of the runtime
AUDIT-*.md
DEEP-VERIFICATION-*.md
TEST-*.md
RECONCILIATION-*.md
LAUNCH-PREP.md
TENANT-GUARDRAILS.md
FEATURE-PASS-*.md
BUILD-SUMMARY.md
CODEX-AUDIT-FIXES.md
ROADMAP.md
CHANGELOG.md
SECURITY.md
CONTRIBUTING.md
wotw-*.md
wotw-*.md:Zone.Identifier

# Lockfile & npm cache (kept package.json + pnpm-lock.yaml in COPY)
.npmrc
